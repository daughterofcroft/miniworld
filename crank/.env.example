# ── Shared (required) ──
MINIWORLD_PACKAGE_ID=0x...
CRANK_SECRET_KEY=base64encodedkey

# ── Walrus (optional, defaults shown) ──
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space

# ── Timing ──
PULSE_INTERVAL_MS=15000
SNAPSHOT_EVERY_N=10

# ── Multi-world: create worlds.json with array of:
#    { worldId, pulseCapId, name, harvestCapId?, pulsePoolId? }
# ── Single-world: use these env vars (worlds.json takes priority if it exists)
MINIWORLD_WORLD_ID=0x...
MINIWORLD_PULSE_CAP_ID=0x...

# ── Multi-agent: create agents.json with array of:
#    { worldId, agentId, agentCapId, name }
# ── Single-agent: use env vars in .env.agent.example (agents.json takes priority)
